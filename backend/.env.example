# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored so your password never gets committed.

# OBS WebSocket server (Tools -> WebSocket Server Settings in OBS).
# Leave OBS_WS_URL as-is unless you changed the port.
OBS_WS_URL=ws://localhost:4455

# The password OBS shows in that same settings dialog.
# If you disabled authentication in OBS, leave this blank.
OBS_WS_PASSWORD=

# --- Twitch EventSub (Phase 7) ---------------------------------------------
# From https://dev.twitch.tv/console/apps — register an app with the OAuth
# redirect URL http://localhost:17563 and copy its Client ID / Secret here.
# These identify the *application*; they say nothing about whose data it reads.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# The login name of the channel to watch (your broadcaster account, which is
# also the account you authorize with in the browser on first run).
TWITCH_CHANNEL=

# Optional: point EventSub at the Twitch CLI mock server instead of real
# Twitch, for testing without a live stream. Start it with:
#   twitch event websocket start-server -S -p 8081
# then fire events with (-t sets the target broadcaster id; use YOUR id so it
# matches the subscription — a bare trigger uses a random id that won't match):
#   twitch event trigger channel.follow --transport=websocket -t <your-user-id>
# TWITCH_EVENTSUB_WS is a full ws:// URL; TWITCH_EVENTSUB_API is a *base* URL
# (the library appends `eventsub/subscriptions` itself — don't include it).
# Leave both blank to talk to the real Twitch.
TWITCH_EVENTSUB_WS=ws://127.0.0.1:8081/ws
TWITCH_EVENTSUB_API=http://127.0.0.1:8081/
