# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored so your password never gets committed.

# OBS WebSocket server (Tools -> WebSocket Server Settings in OBS).
# Leave OBS_WS_URL as-is unless you changed the port.
OBS_WS_URL=ws://localhost:4455

# The password OBS shows in that same settings dialog.
# If you disabled authentication in OBS, leave this blank.
OBS_WS_PASSWORD=
